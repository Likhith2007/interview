<Window x:Class="OverlayDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Overlay Detector - Interview Monitor" Height="600" Width="800"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="Video Interview Overlay Detector" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="Monitors for unauthorized overlay windows during video interviews" 
                           FontSize="12" 
                           Foreground="#ECF0F1" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Control Section -->
        <Border Grid.Row="1" Background="White" Padding="20">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="StartButton"
                        Click="StartMonitoring_Click"
                        Background="#27AE60" 
                        Foreground="White" 
                        Padding="15,10" 
                        FontSize="14" 
                        FontWeight="Bold"
                        MinWidth="120"
                        Cursor="Hand">
                    Start Monitoring
                </Button>
                <Button x:Name="StopButton"
                        Click="StopMonitoring_Click"
                        Background="#E74C3C" 
                        Foreground="White" 
                        Padding="15,10" 
                        FontSize="14" 
                        FontWeight="Bold"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        IsEnabled="False">
                    Stop Monitoring
                </Button>
                <Button x:Name="ClearButton"
                        Click="ClearDetections_Click"
                        Background="#3498DB" 
                        Foreground="White" 
                        Padding="15,10" 
                        FontSize="14" 
                        FontWeight="Bold"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        Cursor="Hand">
                    Clear List
                </Button>
                <Button x:Name="ViewLogsButton"
                        Click="ViewLogs_Click"
                        Background="#9B59B6" 
                        Foreground="White" 
                        Padding="15,10" 
                        FontSize="14" 
                        FontWeight="Bold"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        Cursor="Hand">
                    View Logs
                </Button>
                <Button x:Name="DebugButton"
                        Click="ShowDebug_Click"
                        Background="#E67E22" 
                        Foreground="White" 
                        Padding="15,10" 
                        FontSize="14" 
                        FontWeight="Bold"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        Cursor="Hand">
                    Debug Info
                </Button>
                <Button x:Name="SettingsButton"
                        Click="Settings_Click"
                        Background="#16A085"
                        Foreground="White"
                        Padding="15,10"
                        FontSize="14"
                        FontWeight="Bold"
                        MinWidth="120"
                        Margin="10,0,0,0"
                        Cursor="Hand">
                    ⚙️ Settings
                </Button>
                <TextBlock x:Name="StatusText" 
                           Text="Status: Idle" 
                           Foreground="#7F8C8D" 
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Detected Overlays List -->
        <Border Grid.Row="2" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Detected Overlays (Real-time)" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1"
                          x:Name="OverlaysDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Background="White"
                          BorderBrush="#BDC3C7"
                          BorderThickness="1"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Process Name" 
                                            Binding="{Binding ProcessName}" 
                                            Width="150"/>
                        <DataGridTextColumn Header="Window Title" 
                                            Binding="{Binding WindowTitle}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Window Class" 
                                            Binding="{Binding WindowClass}" 
                                            Width="150"/>
                        <DataGridTextColumn Header="Detected At" 
                                            Binding="{Binding DetectedAt, StringFormat='HH:mm:ss'}" 
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer Section -->
        <Border Grid.Row="3" Background="#ECF0F1" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="CountText" 
                           Text="Overlays Detected: 0" 
                           Foreground="#2C3E50" 
                           FontSize="12"
                           FontWeight="Bold"/>
                <TextBlock x:Name="WarningText" 
                           Text="" 
                           Foreground="#E74C3C" 
                           FontSize="12"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
